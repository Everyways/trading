# =============================================================================
# trading-routines — Environment Variables
# Copy to .env and fill in. NEVER commit .env to git.
# =============================================================================

# --- Anthropic API (required) ---
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-6
MAX_TOKENS=8192
MAX_WEB_SEARCHES=10

# --- Telegram (optional but recommended) ---
# Same bot token and chat ID as the trading bot — shared channel, different prefix
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Paths (defaults work in Docker; override only if running bare) ---
REPORTS_DIR=/app/reports
CONFIG_FILE=/app/config.yaml
PROMPTS_DIR=/app/prompts

# --- Scheduler timezone ---
TIMEZONE=Europe/Paris
