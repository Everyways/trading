# =============================================================================
# Trading Bot — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to git.
# =============================================================================

# --- Database ---
DATABASE_URL=postgresql+asyncpg://trading:trading@localhost:5432/trading
DATABASE_URL_SYNC=postgresql+psycopg2://trading:trading@localhost:5432/trading

# --- Security ---
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=change-me

# --- Alpaca ---
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_API_SECRET=your-alpaca-api-secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets   # paper
# ALPACA_BASE_URL=https://api.alpaca.markets       # live

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID_GLOBAL=

# --- Trading safety ---
# Set to true ONLY when running on Raspberry Pi or server — never on a laptop for live trading
ALLOW_LIVE_ON_LAPTOP=false

# Emergency override for monthly stop (requires YAML change too, creates audit log CRITICAL)
TRADING_BOT_ACCEPT_MONTHLY_STOP_OVERRIDE=

# Per-strategy live approval (replace STRATEGY_NAME with uppercase strategy name)
# TRADING_BOT_LIVE_APPROVAL_RSI_MEAN_REVERSION=yes
# TRADING_BOT_LIVE_APPROVAL_MA_CROSSOVER=yes
# TRADING_BOT_LIVE_APPROVAL_BREAKOUT=yes

# --- Paths ---
DATA_DIR=./data
CONFIG_DIR=./config

# --- Environment ---
ENVIRONMENT=development  # development | production

# --- Panic button ---
# TRADING_BOT_PANIC=1  # Uncomment to engage global kill switch immediately
